{
  "name": "sndr-gui-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc -b",
    "gen:api": "openapi-typescript ${SNDR_API_BASE:-http://127.0.0.1:8765}/openapi.json -o src/api/schema.gen.ts",
    "check:api": "openapi-typescript ${SNDR_API_BASE:-http://127.0.0.1:8765}/openapi.json -o /tmp/sndr-schema.check.ts && diff -q src/api/schema.gen.ts /tmp/sndr-schema.check.ts",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "lint": "eslint ."
  },
  "dependencies": {
    "@ibm/plex": "^6.4.0",
    "@lingui/core": "^4.11.4",
    "@lingui/macro": "^4.11.4",
    "@lingui/react": "^4.11.4",
    "@tanstack/react-query": "^5.62.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@lingui/cli": "^4.11.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "openapi-typescript": "^7.13.0",
    "sass": "^1.83.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.14"
  }
}
